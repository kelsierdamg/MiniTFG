<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    x:Class="MiniTFG.RecipeDetailPopup">

    <VerticalStackLayout Padding="20" Spacing="15" BackgroundColor="#9C40F7"
                         HorizontalOptions="Center" VerticalOptions="Center"
                         WidthRequest="320">

        <Label x:Name="TituloLabel" FontSize="22" FontAttributes="Bold"
               HorizontalOptions="Center" TextColor="White" />

        <Image x:Name="RecetaImage" HeightRequest="200" Aspect="AspectFit" />

        <Label x:Name="DescripcionLabel" FontSize="14" TextColor="White"
               LineBreakMode="WordWrap" />

        <Button Text="Let me cook!"
                BackgroundColor="#7A1CCF"
                TextColor="White"
                FontAttributes="Bold"
                CornerRadius="10"
                Clicked="OnLetMeCookClicked" />

    </VerticalStackLayout>
</toolkit:Popup>
