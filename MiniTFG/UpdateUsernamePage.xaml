<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MiniTFG.UpdateUsernamePage"
             Title="UpdateUsernamePage">
    <VerticalStackLayout>
        <Entry x:Name="UsernameEntry"
               Placeholder="Nuevo nombre de usuario"
               FontSize="18" />
        
        <Button Text="Actualizar nombre de usuario"
                BackgroundColor="#9C40F7"
                TextColor="White"
                CornerRadius="15"
                HeightRequest="50"
                Clicked="GuardarUsernameClicked" />
    </VerticalStackLayout>
</ContentPage>