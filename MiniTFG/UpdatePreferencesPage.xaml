<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MiniTFG.UpdatePreferencesPage"
             Title="UpdatePreferencesPage">
    <VerticalStackLayout>
        <Label Text="Selecciona todas tus alergias y preferencias:"
               FontSize="18"
               VerticalOptions="Center" 
               HorizontalOptions="Center" />

        <CollectionView ItemsSource="{Binding Preferencias}">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <HorizontalStackLayout Spacing="10" Padding="10">
                        <CheckBox IsChecked="{Binding Seleccion}" VerticalOptions="Center" />
                        <Label Text="{Binding Nombre}" FontSize="18" VerticalOptions="Center" />
                    </HorizontalStackLayout>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Button
            Text="Actualizar preferencias"
            Clicked="UpdateClicked"
            HeightRequest="50"
            CornerRadius="15"
            BackgroundColor="#9C40F7"
            TextColor="White" />
    </VerticalStackLayout>
</ContentPage>