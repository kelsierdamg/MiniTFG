<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MiniTFG.AllergiesPage">
    <ScrollView>
        <VerticalStackLayout Spacing="20" Padding="30">
            <Label 
                Text="Selecciona todas tus alergias:"
                FontSize="28"
                FontAttributes="Bold"
                VerticalOptions="Center" 
                HorizontalOptions="Center" />

            <CollectionView ItemsSource="{Binding Alergenos}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <HorizontalStackLayout Spacing="10" Padding="10">
                            <CheckBox IsChecked="{Binding Seleccion}" VerticalOptions="Center" />
                            <Label Text="{Binding Nombre}" FontSize="18" VerticalOptions="Center" />
                        </HorizontalStackLayout>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Button
                Text="Siguiente"
                x:Name="btnNext"
                Clicked="NextClicked"
                HeightRequest="50"
                CornerRadius="0"
                BackgroundColor="#9C40F7"
                VerticalOptions="Center"
                HorizontalOptions="Fill" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>