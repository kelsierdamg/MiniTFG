<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MiniTFG.UpdatePasswordPage"
             Title="UpdatePasswordPage">
    <VerticalStackLayout>
        <Entry x:Name="CurrentPasswordEntry"
               Placeholder="Contraseña actual"
               FontSize="18"
               IsPassword="True" />

        <Entry x:Name="NewPasswordEntry"
               Placeholder="Nueva contraseña"
               FontSize="18"
               IsPassword="True" />

        <Entry x:Name="ConfirmPasswordEntry"
                Placeholder="Confirmar nueva contraseña"
                FontSize="18"
                IsPassword="True" />

        <Button Text="Actualizar contraseña"
                BackgroundColor="#9C40F7"
                TextColor="White"
                CornerRadius="15"
                HeightRequest="50"
                Clicked="GuardarPasswordClicked" />
    </VerticalStackLayout>
</ContentPage>